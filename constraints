NOT NULL
CREATE TABLE table_name (
    col1  NUMBER   NOT NULL,
    col2  VARCHAR2(50) NOT NULL,
    col3  NUMBER
);
UNIQUE
CREATE TABLE table_name (
    col1  NUMBER  UNIQUE NOT NULL,
    col2  VARCHAR2(50)
);
PRIMARY KEY
CREATE TABLE table_name (
    col1  NUMBER,
    col2  VARCHAR2(50),
    CONSTRAINT pk_name PRIMARY KEY (col1)
);
FOREIGN KEY
CREATE TABLE parent_table (
    parent_id  NUMBER  PRIMARY KEY,
    parent_col VARCHAR2(50)
);

CREATE TABLE child_table (
    child_id   NUMBER  PRIMARY KEY,
    child_col  VARCHAR2(50),
    parent_id  NUMBER,
    FOREIGN KEY (parent_id) REFERENCES parent_table(parent_id)
        ON DELETE CASCADE
);
CHECK
CREATE TABLE table_name (
    col1  NUMBER,
    col2  NUMBER  CHECK (col2 >= 0)
);
DEFAULT
CREATE TABLE table_name (
    col1  NUMBER,
    col2  VARCHAR2(30)  DEFAULT 'default_value'
);
